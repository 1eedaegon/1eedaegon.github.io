# ==================================================================
# LOCAL DEVELOPMENT ONLY — this file is never used by deploys.
#
# Production values come from GitHub in this priority order:
#   1. Repository variables (Settings > Secrets and variables >
#      Actions > Variables) — same names as below
#   2. Auto-derived defaults: SITE_NAME / SITE_TITLE / SITE_AUTHOR /
#      GH_USERNAME fall back to the repository owner; SITE_URL and
#      BASE_PATH come from the Pages configuration
# So a template copy deploys correctly with an EMPTY variable list.
# ==================================================================

# ===========================================
# Site Configuration
# ===========================================
SITE_NAME="Your Name"
SITE_TITLE="Your Blog Title"
SITE_DESCRIPTION="A minimal, elegant technical blog built with Astro and Monochrome Edge UI"
SITE_URL="https://yourusername.github.io"
BASE_PATH="/your-repo-name"  # GitHub Pages project site: "/repo-name", user site or custom domain: "/"
SITE_AUTHOR="Your Name"

# ===========================================
# Social Links
# ===========================================
# In CI use GH_USERNAME (GitHub Actions reserves the GITHUB_ env prefix);
# locally either name works.
GITHUB_USERNAME="yourusername"
TWITTER_USERNAME=""
EMAIL="your.email@example.com"

# ===========================================
# Comments System
# Choose ONE: none, giscus, utterances, disqus, cusdis
# ===========================================
COMMENTS_PROVIDER=none

# --- Giscus (if provider=giscus) ---
# Get config from: https://giscus.app
GISCUS_REPO=""
GISCUS_REPO_ID=""
GISCUS_CATEGORY=""
GISCUS_CATEGORY_ID=""
GISCUS_MAPPING="pathname"
GISCUS_THEME="preferred_color_scheme"
GISCUS_LANG="ko"

# --- Utterances (if provider=utterances) ---
# UTTERANCES_REPO="username/repo"
# UTTERANCES_THEME="github-light"
# UTTERANCES_ISSUE_TERM="pathname"

# --- Disqus (if provider=disqus) ---
# DISQUS_SHORTNAME="your-shortname"

# --- Cusdis (if provider=cusdis) ---
# CUSDIS_APP_ID="your-app-id"
# CUSDIS_HOST="https://cusdis.com"

# ===========================================
# Search System
# Choose: local, algolia, none
# ===========================================
SEARCH_PROVIDER=local

# --- Algolia (if provider=algolia) ---
# Get credentials from: https://www.algolia.com
# IMPORTANT: Use "Search-Only API Key" only. NEVER use Admin API Key here.
# ALGOLIA_APP_ID="your-app-id"
# ALGOLIA_API_KEY="your-search-only-api-key"
# ALGOLIA_INDEX_NAME="blog"

# ===========================================
# Analytics
# Multiple analytics can be enabled simultaneously
# ===========================================

# --- Google Analytics 4 ---
GA4_ENABLED=false
GA4_MEASUREMENT_ID=""

# Legacy support (will use GA4_MEASUREMENT_ID if set)
# GOOGLE_ANALYTICS_ID=""

# --- Plausible Analytics ---
PLAUSIBLE_ENABLED=false
PLAUSIBLE_DOMAIN=""
PLAUSIBLE_SRC="https://plausible.io/js/script.js"

# ===========================================
# Monitoring
# ===========================================

# --- Sentry ---
SENTRY_ENABLED=false
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="1.0"

# ===========================================
# Theme & UI
# ===========================================
DEFAULT_THEME="cold"  # warm | cold
DEFAULT_MODE="auto"   # light | dark | auto

# ===========================================
# Quick Start Examples
# ===========================================

# Example 1: Enable Giscus Comments
# COMMENTS_PROVIDER=giscus
# GISCUS_REPO="username/blog"
# GISCUS_REPO_ID="R_xxxxx"
# GISCUS_CATEGORY="General"
# GISCUS_CATEGORY_ID="DIC_xxxxx"

# Example 2: Enable Google Analytics
# GA4_ENABLED=true
# GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Example 3: Enable Plausible Analytics
# PLAUSIBLE_ENABLED=true
# PLAUSIBLE_DOMAIN="yourblog.com"

# Example 4: Enable Sentry Monitoring
# SENTRY_ENABLED=true
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Example 5: Switch to Utterances
# COMMENTS_PROVIDER=utterances
# UTTERANCES_REPO="username/blog"

# Example 6: Use Algolia Search
# SEARCH_PROVIDER=algolia
# ALGOLIA_APP_ID="XXXXXXXXXX"
# ALGOLIA_API_KEY="xxxxxxxxxxxxxxxxxxxxx"
# ALGOLIA_INDEX_NAME="blog"
