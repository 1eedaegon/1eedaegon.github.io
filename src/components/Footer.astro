---
import { SITE } from '../config';

const currentYear = new Date().getFullYear();
---

<footer class="footer" id="footer">
  <div class="container">
    <div class="footer-content">
      <p class="footer-text">
        © {currentYear}
        {SITE.author}. All rights reserved.
      </p>
      <p class="footer-text">
        Built with <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer">Astro</a
        > + <a
          href="https://github.com/1eedaegon/monochrome-edge"
          target="_blank"
          rel="noopener noreferrer"
          class="logo-link"
        >
          <img
            src={`${import.meta.env.BASE_URL}monochrome-edge-logo.svg`}
            alt="MONOCHROME EDGE"
            class="footer-logo"
            width="124"
            height="16"
          />
        </a>
      </p>
    </div>
  </div>
</footer>

<script>
  function updateFooterOpacity() {
    const footer = document.getElementById('footer');
    if (!footer) return;

    if (window.scrollY > 50) {
      footer.classList.add('scrolled');
    } else {
      footer.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', updateFooterOpacity, { passive: true });
  updateFooterOpacity();
</script>

<style>
  .footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 0;
    border-top: 1px solid var(--theme-border);
    background-color: var(--theme-bg);
    opacity: 1;
    transition:
      opacity 0.3s ease,
      padding 0.2s ease;
    z-index: 10;
  }

  .footer.scrolled {
    opacity: 0.5;
  }

  .footer:hover {
    opacity: 1;
  }

  .footer-content {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-text {
    color: var(--theme-text-secondary);
    font-size: 0.75rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .footer-text a {
    color: var(--theme-text-secondary);
    text-decoration: none;
    transition: color var(--transition-speed);
  }

  .footer-text a:hover {
    color: var(--theme-accent);
  }

  .logo-link {
    font-weight: 600;
    letter-spacing: 0.05em;
    display: inline-flex;
    align-items: center;
  }

  .footer-logo {
    height: 16px;
    width: auto;
    opacity: 0.7;
    transition: opacity var(--transition-speed);
  }

  .logo-link:hover .footer-logo {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .footer {
      position: relative;
      padding: 1rem 0;
    }

    .footer-content {
      flex-direction: column;
      gap: 0.25rem;
      text-align: center;
    }

    .footer-text {
      font-size: 0.6875rem;
    }
  }
</style>
