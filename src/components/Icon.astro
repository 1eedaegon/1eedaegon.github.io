---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={name === 'github' ? 'currentColor' : 'none'}
  stroke="currentColor"
  stroke-width="2"
  class:list={['icon', className]}
  aria-hidden="true"
>
  <Fragment set:html={icons[name]} />
</svg>

<style>
  .icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>
