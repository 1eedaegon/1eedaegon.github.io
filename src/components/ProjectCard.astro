---
import Icon from './Icon.astro';

interface Props {
  title: string;
  description: string;
  status?: 'Active' | 'WIP' | 'Completed' | 'Archived';
  tags?: string[];
  githubUrl?: string;
  demoUrl?: string;
  homepage?: string;
}

const {
  title,
  description,
  status,
  tags = [],
  githubUrl,
  demoUrl,
  homepage,
} = Astro.props;
---

<article class="project-card">
  <div class="project-header">
    <h3 class="project-title">{title}</h3>
    {
      status && (
        <span class="project-status" data-status={status.toLowerCase()}>
          {status}
        </span>
      )
    }
  </div>

  <p class="project-description">{description}</p>

  {
    tags.length > 0 && (
      <div class="project-tags">
        {tags.map((tag) => (
          <span class="project-tag">{tag}</span>
        ))}
      </div>
    )
  }

  <div class="project-links">
    {
      githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="project-link"
        >
          <Icon name="github" size={16} />
          <span>GitHub</span>
        </a>
      )
    }
    {
      demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="project-link"
        >
          <Icon name="external-link" size={16} />
          <span>Demo</span>
        </a>
      )
    }
    {
      homepage && (
        <a
          href={homepage}
          target="_blank"
          rel="noopener noreferrer"
          class="project-link"
        >
          <Icon name="link" size={16} />
          <span>Website</span>
        </a>
      )
    }
  </div>
</article>

<style>
  .project-card {
    background-color: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-radius: var(--border-radius);
    padding: 1.5rem;
    transition: all var(--transition-speed);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card:hover {
    box-shadow: var(--theme-shadow-md);
    border-color: var(--theme-accent);
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    color: var(--theme-text-primary);
  }

  .project-status {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .project-status[data-status='active'] {
    background-color: rgba(123, 159, 96, 0.1);
    color: #7b9f60;
  }

  .project-status[data-status='wip'] {
    background-color: rgba(212, 165, 116, 0.1);
    color: #d4a574;
  }

  .project-status[data-status='completed'] {
    background-color: rgba(107, 114, 128, 0.1);
    color: #6b7280;
  }

  .project-status[data-status='archived'] {
    background-color: rgba(139, 58, 58, 0.1);
    color: #8b3a3a;
  }

  .project-description {
    color: var(--theme-text-secondary);
    margin: 0;
    line-height: 1.6;
    font-size: var(--font-size-body);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-tag {
    font-size: 0.875rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--theme-bg);
    border: 1px solid var(--theme-border);
    border-radius: calc(var(--border-radius) / 2);
    color: var(--theme-text-secondary);
    font-weight: 500;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--theme-border);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--theme-accent);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color var(--transition-speed);
  }

  .project-link:hover {
    color: var(--theme-highlight);
  }

  .project-link :global(.icon) {
    flex-shrink: 0;
  }
</style>
