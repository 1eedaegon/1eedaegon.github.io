---
import type { MarkdownHeading } from 'astro';
import { generateTOC } from '../utils/toc';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = generateTOC(headings);
---

{
  toc.length > 0 && (
    <nav class="toc" aria-label="Table of Contents">
      <h2 class="toc-title">Table of Contents</h2>
      <ul class="toc-list">
        {toc.map((item) => (
          <li class={`toc-item depth-${item.depth}`}>
            <a href={`#${item.slug}`} class="toc-link">
              {item.text}
            </a>
            {item.children.length > 0 && (
              <ul class="toc-sublist">
                {item.children.map((child) => (
                  <li class={`toc-item depth-${child.depth}`}>
                    <a href={`#${child.slug}`} class="toc-link">
                      {child.text}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc {
    position: sticky;
    top: 6rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    padding: 1.5rem;
    background-color: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-radius: var(--border-radius);
    align-self: start;
  }

  .toc-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: var(--theme-text-primary);
  }

  .toc-list,
  .toc-sublist {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-sublist {
    margin-left: 1rem;
    margin-top: 0.5rem;
  }

  .toc-item {
    margin-bottom: 0.5rem;
  }

  .toc-link {
    display: block;
    padding: 0.25rem 0;
    color: var(--theme-text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: color 0.2s ease;
    border-left: 2px solid transparent;
    padding-left: 0.5rem;
  }

  .toc-link:hover {
    color: var(--theme-accent);
    border-left-color: var(--theme-accent);
    text-decoration: none;
  }

  .toc-link.active {
    color: var(--theme-accent);
    border-left-color: var(--theme-accent);
    font-weight: 600;
  }

  .depth-3 .toc-link {
    font-size: 0.85rem;
    padding-left: 0.75rem;
  }

  /* Mobile: Collapsible TOC */
  @media (max-width: 1024px) {
    .toc {
      position: relative;
      top: 0;
      max-height: none;
      margin-bottom: 2rem;
    }

    .toc-title {
      cursor: pointer;
      user-select: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .toc-title::after {
      content: '▼';
      font-size: 0.8rem;
      transition: transform 0.2s ease;
    }

    .toc.collapsed .toc-title::after {
      transform: rotate(-90deg);
    }

    .toc.collapsed .toc-list {
      display: none;
    }
  }

  /* Hide scrollbar but keep functionality */
  .toc::-webkit-scrollbar {
    width: 4px;
  }

  .toc::-webkit-scrollbar-track {
    background: var(--theme-bg);
  }

  .toc::-webkit-scrollbar-thumb {
    background: var(--theme-border);
    border-radius: 2px;
  }

  .toc::-webkit-scrollbar-thumb:hover {
    background: var(--theme-accent);
  }
</style>

<script>
  let headingObserver: IntersectionObserver | null = null;

  function initTOC() {
    const toc = document.querySelector('.toc');
    headingObserver?.disconnect();
    if (!toc) return;

    // Active heading tracking
    headingObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.getAttribute('id');
          document.querySelectorAll('.toc-link').forEach((link) => {
            link.classList.remove('active');
          });
          document
            .querySelector(`.toc-link[href="#${id}"]`)
            ?.classList.add('active');
        });
      },
      { rootMargin: '-100px 0px -66%', threshold: 1 },
    );

    document.querySelectorAll('article h2, article h3').forEach((heading) => {
      headingObserver?.observe(heading);
    });

    // Mobile: TOC collapse toggle
    const tocTitle = toc.querySelector('.toc-title') as HTMLElement | null;
    if (tocTitle && tocTitle.dataset.initialized !== 'true') {
      tocTitle.dataset.initialized = 'true';
      tocTitle.addEventListener('click', () => {
        if (window.innerWidth <= 1024) {
          toc.classList.toggle('collapsed');
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTOC);
  } else {
    initTOC();
  }

  // Re-initialize after view transitions
  document.addEventListener('astro:after-swap', initTOC);
</script>
