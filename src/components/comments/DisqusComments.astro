---
import { INTEGRATIONS } from '../../config';

const config = INTEGRATIONS.comments.disqus;
if (!config.shortname || !/^[a-zA-Z0-9-]+$/.test(config.shortname)) {
  return null;
}

const pageUrl = Astro.url.href;
const pageIdentifier = Astro.url.pathname;
---

<div class="comments-section">
  <h2 class="comments-title">Comments</h2>
  <div id="disqus_thread"></div>
</div>

<script is:inline define:vars={{ shortname: config.shortname, pageUrl, pageIdentifier }}>
  window['disqus_config'] = function () {
    this.page.url = pageUrl;
    this.page.identifier = pageIdentifier;
  };

  (function() {
    var d = document, s = d.createElement('script');
    s.src = `https://${shortname}.disqus.com/embed.js`;
    s.setAttribute('data-timestamp', +new Date());
    (d.head || d.body).appendChild(s);
  })();
</script>

<style>
  .comments-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 2px solid var(--theme-border);
  }

  .comments-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--theme-text-primary);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .comments-section {
      margin-top: 3rem;
      padding-top: 1.5rem;
    }

    .comments-title {
      font-size: 1.125rem;
    }
  }
</style>
