---
interface Props {
  items: Array<{
    id: string;
    data: {
      type: 'contribution';
      order?: number;
      project: string;
      role: string;
      period: string;
      description: string;
      link: string;
      technologies?: string[];
    };
  }>;
}

const { items } = Astro.props;
const sortedItems = [...items].sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

{sortedItems.length > 0 && (
  <section class="profile-section contribution-section">
    <h2 class="section-title">Open-Source Contributions</h2>
    <div class="section-content">
      {sortedItems.map((item) => (
        <div class="contribution-item">
          <h3 class="item-title">
            <a href={item.data.link} target="_blank" rel="noopener noreferrer">
              {item.data.project}
            </a>
          </h3>
          <div class="item-meta">
            <span class="role">{item.data.role}</span>
            <span class="period">{item.data.period}</span>
          </div>
          <p class="item-description">{item.data.description}</p>
          {item.data.technologies && item.data.technologies.length > 0 && (
            <div class="item-technologies">
              {item.data.technologies.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          )}
          <a href={item.data.link} target="_blank" rel="noopener noreferrer" class="item-link">
            View on GitHub →
          </a>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .profile-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--theme-text-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--theme-border);
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contribution-item {
    padding: 0;
  }

  .item-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .item-title a {
    color: var(--theme-text-primary);
    text-decoration: none;
    transition: color var(--transition-speed);
  }

  .item-title a:hover {
    color: var(--theme-accent);
  }

  .item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
  }

  .role {
    font-weight: 600;
    color: var(--theme-text-primary);
  }

  .period {
    color: var(--theme-text-secondary);
  }

  .item-description {
    color: var(--theme-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .item-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tech-tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.625rem;
    background-color: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-radius: calc(var(--border-radius) / 2);
    color: var(--theme-text-primary);
  }

  .item-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.9rem;
    color: var(--theme-accent);
    text-decoration: none;
    transition: color var(--transition-speed);
  }

  .item-link:hover {
    color: var(--theme-highlight);
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 1.5rem;
    }

    .item-title {
      font-size: 1rem;
    }

    .item-meta {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
