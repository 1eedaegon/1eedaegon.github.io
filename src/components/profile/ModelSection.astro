---
interface Props {
  items: Array<{
    id: string;
    data: {
      type: 'model';
      order?: number;
      name: string;
      description: string;
      tags?: string[];
      link: string;
      platform?: string;
    };
  }>;
}

const { items } = Astro.props;
const sortedItems = [...items].sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

{sortedItems.length > 0 && (
  <section class="profile-section model-section">
    <h2 class="section-title">Models</h2>
    <div class="section-content">
      {sortedItems.map((item) => (
        <div class="model-item">
          <h3 class="item-title">
            <a href={item.data.link} target="_blank" rel="noopener noreferrer">
              {item.data.name}
            </a>
          </h3>
          <p class="item-description">{item.data.description}</p>

          {item.data.tags && item.data.tags.length > 0 && (
            <div class="item-tags">
              {item.data.tags.map((tag) => (
                <span class="badge badge-primary">{tag}</span>
              ))}
            </div>
          )}

          <a href={item.data.link} target="_blank" rel="noopener noreferrer" class="model-link">
            View on {item.data.platform || 'Hugging Face'} →
          </a>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .profile-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--theme-text-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--theme-border);
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .model-item {
    background-color: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-radius: var(--border-radius);
    padding: 1.25rem;
    transition: transform var(--transition-speed), box-shadow var(--transition-speed);
  }

  .model-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--theme-shadow-md);
  }

  .item-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .item-title a {
    color: var(--theme-text-primary);
    text-decoration: none;
    transition: color var(--transition-speed);
  }

  .item-title a:hover {
    color: var(--theme-accent);
  }

  .item-description {
    color: var(--theme-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }

  .model-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.9rem;
    color: var(--theme-accent);
    text-decoration: none;
    transition: color var(--transition-speed);
    padding-top: 0.5rem;
    border-top: 1px solid var(--theme-border);
    width: 100%;
  }

  .model-link:hover {
    color: var(--theme-highlight);
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 1.5rem;
    }

    .item-title {
      font-size: 1rem;
    }

    .model-item {
      padding: 1rem;
    }
  }
</style>
