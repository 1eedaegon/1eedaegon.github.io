---
interface Props {
  items: Array<{
    id: string;
    data: {
      type: 'service';
      order?: number;
      name: string;
      description: string;
      status?: 'active' | 'beta' | 'development';
      tags?: string[];
      link: string;
    };
  }>;
}

const { items } = Astro.props;
const sortedItems = [...items].sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0),
);

const statusBadgeClass = (status?: string) => {
  switch (status) {
    case 'active':
      return 'badge-success';
    case 'beta':
      return 'badge-warning';
    case 'development':
      return 'badge-default';
    default:
      return 'badge-success';
  }
};

const statusLabel = (status?: string) => {
  return status ? status.charAt(0).toUpperCase() + status.slice(1) : 'Active';
};
---

{
  sortedItems.length > 0 && (
    <section class="profile-section service-section">
      <h2 class="section-title">Services</h2>
      <div class="section-content">
        {sortedItems.map((item) => (
          <div class="service-item">
            <h3 class="item-title">
              <a
                href={item.data.link}
                target="_blank"
                rel="noopener noreferrer"
              >
                {item.data.name}
              </a>
            </h3>
            <p class="item-description">{item.data.description}</p>

            <div class="item-meta">
              <span class={`badge ${statusBadgeClass(item.data.status)}`}>
                {statusLabel(item.data.status)}
              </span>

              {item.data.tags && item.data.tags.length > 0 && (
                <div class="item-tags">
                  {item.data.tags.map((tag) => (
                    <span class="badge badge-default">{tag}</span>
                  ))}
                </div>
              )}
            </div>

            <a
              href={item.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="service-link"
            >
              Visit Service →
            </a>
          </div>
        ))}
      </div>
    </section>
  )
}

<style>
  .profile-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--theme-text-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--theme-border);
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .service-item {
    background-color: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-radius: var(--border-radius);
    padding: 1.25rem;
    transition:
      transform var(--transition-speed),
      box-shadow var(--transition-speed);
  }

  .service-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--theme-shadow-md);
  }

  .item-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .item-title a {
    color: var(--theme-text-primary);
    text-decoration: none;
    transition: color var(--transition-speed);
  }

  .item-title a:hover {
    color: var(--theme-accent);
  }

  .item-description {
    color: var(--theme-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .item-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.9rem;
    color: var(--theme-accent);
    text-decoration: none;
    transition: color var(--transition-speed);
    padding-top: 0.5rem;
    border-top: 1px solid var(--theme-border);
    width: 100%;
  }

  .service-link:hover {
    color: var(--theme-highlight);
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 1.5rem;
    }

    .item-title {
      font-size: 1rem;
    }

    .service-item {
      padding: 1rem;
    }
  }
</style>
