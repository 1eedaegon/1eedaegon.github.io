---
interface Props {
  items: Array<{
    id: string;
    data: {
      type: 'vitae';
      order?: number;
      title: string;
      description?: string;
      url: string;
    };
  }>;
}

const { items } = Astro.props;
const sortedItems = [...items].sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

{sortedItems.length > 0 && (
  <section class="profile-section vitae-section">
    <h2 class="section-title">Curriculum Vitae</h2>
    <div class="section-content">
      {sortedItems.map((item) => (
        <div class="vitae-item">
          <p class="vitae-description">
            {item.data.description || 'Download my full CV for more details about my background and experience.'}
          </p>
          <a href={item.data.url} class="vitae-link btn btn-primary" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            {item.data.title}
          </a>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .profile-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--theme-text-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--theme-border);
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .vitae-item {
    padding: 0;
  }

  .vitae-description {
    color: var(--theme-text-secondary);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .vitae-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .vitae-link svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 1.5rem;
    }
  }
</style>
