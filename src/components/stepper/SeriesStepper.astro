---
interface Step {
  indicator: string;
  labelTitle: string;
  labelDesc: string;
  title: string;
  desc: string;
  state: 'pending' | 'active' | 'completed' | 'failed' | 'error';
  href: string;
}

interface Props {
  steps: Step[];
  id?: string;
  layout?: 'horizontal' | 'vertical' | 'snake';
  type?: 'default' | 'text';
}

const {
  steps,
  id = 'stepper',
  layout = 'snake',
  type = 'default',
} = Astro.props;

// The Stepper renders labels as SVG <text>, which neither wraps nor clips.
// Its built-in cap is 30 characters, but wide glyphs (hangul ≈ 2× latin
// width) still overflow the node boxes — so truncate by display width here.
const TITLE_WIDTH_BUDGET = 20; // in latin-character units
const DESC_WIDTH_BUDGET = 22;

const WIDE_GLYPH = /[ᄀ-ᇿ⺀-꓏가-힣豈-﫿＀-｠]/;

function truncateByWidth(text: string, budget: number): string {
  let width = 0;
  let out = '';
  for (const ch of text) {
    const w = WIDE_GLYPH.test(ch) ? 2 : 1;
    if (width + w > budget) return `${out.trimEnd()}…`;
    width += w;
    out += ch;
  }
  return text;
}

const fittedSteps = steps.map((step) => ({
  ...step,
  labelTitle: truncateByWidth(step.labelTitle, TITLE_WIDTH_BUDGET),
  labelDesc: truncateByWidth(step.labelDesc, DESC_WIDTH_BUDGET),
}));
---

<div
  class="stepper"
  id={id}
  data-series-stepper
  data-type={type}
  data-layout={layout}
  data-steps={JSON.stringify(fittedSteps)}
>
</div>

<script>
  import { Stepper } from '@monochrome-edge/ui';

  type StepWithHref = {
    href?: string;
  };

  const stepperInstances = new Map<HTMLElement, InstanceType<typeof Stepper>>();

  function initSeriesSteppers() {
    document
      .querySelectorAll<HTMLElement>('[data-series-stepper]')
      .forEach((stepperEl) => {
        if (stepperEl.dataset.stepperInitialized === 'true') return;

        try {
          const stepper = new Stepper(stepperEl, {
            onStepClick: (step) => {
              const href = (step as StepWithHref).href;
              if (href) {
                window.location.href = href;
              }
            },
          });
          stepperInstances.set(stepperEl, stepper);
          stepperEl.dataset.stepperInitialized = 'true';
        } catch {
          stepperEl.dataset.stepperError = 'true';
        }
      });
  }

  function destroySeriesSteppers() {
    stepperInstances.forEach((stepper, stepperEl) => {
      stepper.destroy();
      delete stepperEl.dataset.stepperInitialized;
    });
    stepperInstances.clear();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSeriesSteppers);
  } else {
    initSeriesSteppers();
  }

  document.addEventListener('astro:before-swap', destroySeriesSteppers);
  document.addEventListener('astro:after-swap', initSeriesSteppers);
</script>
