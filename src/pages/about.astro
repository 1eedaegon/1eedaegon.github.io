---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EducationSection from '../components/profile/EducationSection.astro';
import ExperienceSection from '../components/profile/ExperienceSection.astro';
import ContributionSection from '../components/profile/ContributionSection.astro';
import ResearchSection from '../components/profile/ResearchSection.astro';
import VitaeSection from '../components/profile/VitaeSection.astro';

const page = await getEntry('pages', 'about');
if (!page) throw new Error('About page not found');
const rendered = await render(page);
const Content = rendered.Content;

// Load all profile sections
// @ts-ignore - profile-sections collection type not yet generated
const allProfileSections = await getCollection('profile-sections');

// Group sections by type with proper type narrowing
// @ts-ignore
const educationItems = allProfileSections.filter(item => item.data.type === 'education') as any;
// @ts-ignore
const experienceItems = allProfileSections.filter(item => item.data.type === 'experience') as any;
// @ts-ignore
const contributionItems = allProfileSections.filter(item => item.data.type === 'contribution') as any;
// @ts-ignore
const researchItems = allProfileSections.filter(item => item.data.type === 'research') as any;
// @ts-ignore
const vitaeItems = allProfileSections.filter(item => item.data.type === 'vitae') as any;
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Header />
  <main id="main-content" class="container">
    <article class="about-content">
      <!-- Intro Section (from markdown) -->
      <div class="prose intro-section">
        <Content />
      </div>

      <!-- Profile Sections (from data) -->
      <div class="profile-sections">
        <ExperienceSection items={experienceItems} />
        <ContributionSection items={contributionItems} />
        <ResearchSection items={researchItems} />
        <EducationSection items={educationItems} />
        <VitaeSection items={vitaeItems} />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .about-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    width: 100%;
  }

  @media (min-width: 1201px) and (max-width: 2400px) {
    .about-content {
      max-width: 60%;
    }
  }

  @media (min-width: 2401px) {
    .about-content {
      max-width: 1440px;
    }
  }

  .intro-section {
    margin-bottom: 3rem;
  }

  .prose {
    color: var(--theme-text-primary);
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--theme-text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h2:first-of-type) {
    margin-top: 0;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--theme-text-primary);
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(h4) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--theme-text-primary);
    margin-top: 1rem;
    margin-bottom: 0.25rem;
  }

  .prose :global(h2 a),
  .prose :global(h3 a),
  .prose :global(h4 a) {
    color: inherit;
    text-decoration: none;
  }

  .prose :global(h2 a:hover),
  .prose :global(h3 a:hover),
  .prose :global(h4 a:hover) {
    color: var(--theme-accent);
  }

  .prose :global(p) {
    line-height: 1.5;
    margin-bottom: 0.75rem;
    color: var(--theme-text-primary);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--theme-text-primary);
  }

  .prose :global(a) {
    color: var(--theme-accent);
    text-decoration: none;
    transition: color var(--transition-speed);
  }

  .prose :global(a:hover) {
    color: var(--theme-highlight);
  }

  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.4;
  }

  .prose :global(code) {
    font-family: var(--font-family-mono);
    font-size: 0.875rem;
    background-color: var(--theme-surface);
    padding: 0.125rem 0.375rem;
    border-radius: calc(var(--border-radius) / 2);
    border: 1px solid var(--theme-border);
  }

  .profile-sections {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .about-content {
      padding: 2rem 0;
    }

    .prose :global(h2) {
      font-size: 1.25rem;
      margin-top: 1.5rem;
    }

    .prose :global(h3) {
      font-size: 1rem;
    }
  }
</style>
